{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Add Provider",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cli/main.go",
            "args": [
                "provider",
                "add",
                "--file",
                "${workspaceFolder}/cli/testdata/kiro/provider.json"
            ],
            "env": {},
            "showLog": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Get Provider",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cli/main.go",
            "args": [
                "provider",
                "get",
                "--type",
                "kiro",
                "--name",
                "kiro-team-a"
            ],
            "env": {},
            "showLog": true,
            "console": "integratedTerminal"
        }
    ]
}